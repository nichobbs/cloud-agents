# gemini:base — Gemini CLI runner image.
#
# Provides Google's Gemini CLI inside an ephemeral container.
# The API server sets HARNESS=gemini, MODEL, NATIVE_SESSION_ID, PROMPT,
# REPO_URL, BRANCH, and GEMINI_API_KEY (or GOOGLE_API_KEY) at runtime.
#
# Build:  docker build -t gemini:base -f docker/Dockerfile.gemini docker
# Arch:   linux/amd64

FROM --platform=linux/amd64 node:20-slim

ENV DEBIAN_FRONTEND=noninteractive

# Pinned to a version confirmed to install cleanly (bump deliberately, not
# by dropping the pin back to @latest — an untested "latest" is what took
# the whole Coolify deploy down the first time a sibling harness image ran
# unpinned, see deploy/COOLIFY.md). The retry loop guards against transient
# npm-registry failures, the other documented cause of a mid-build failure.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git bash curl ca-certificates jq \
    && ( n=0; until npm install -g @google/gemini-cli@0.51.0; do \
           n=$((n + 1)); \
           if [ "$n" -ge 3 ]; then echo "npm install -g @google/gemini-cli failed after 3 attempts" >&2; exit 1; fi; \
           echo "npm install -g @google/gemini-cli failed (attempt $n/3), retrying in 5s..." >&2; \
           sleep 5; \
         done ) \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --home-dir /home/gemini-user --shell /bin/bash gemini-user
WORKDIR /workspace
RUN chown gemini-user:gemini-user /workspace

COPY entrypoint-gemini.sh /usr/local/bin/entrypoint.sh
COPY reconcile-repos.sh /usr/local/bin/reconcile-repos.sh
COPY inject-library.sh /usr/local/bin/inject-library.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/reconcile-repos.sh /usr/local/bin/inject-library.sh

USER gemini-user
ENV HOME=/home/gemini-user

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
