# opencode:base — OpenCode runner image.
#
# Provides the OpenCode CLI inside an ephemeral container.
# The API server sets HARNESS=opencode, MODEL, NATIVE_SESSION_ID, PROMPT,
# REPO_URL, BRANCH, and the relevant API key at runtime.
#
# Build:  docker build -t opencode:base -f docker/Dockerfile.opencode docker
# Arch:   linux/amd64

FROM --platform=linux/amd64 node:20-slim

ENV DEBIAN_FRONTEND=noninteractive

# Pinned to a version confirmed to install cleanly (bump deliberately, not
# by dropping the pin back to @latest — an untested "latest" is what took
# the whole Coolify deploy down the first time a sibling harness image ran
# unpinned, see deploy/COOLIFY.md). The retry loop guards against transient
# npm-registry failures, the other documented cause of a mid-build failure.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git bash curl ca-certificates jq \
    && ( n=0; until npm install -g opencode-ai@1.18.4; do \
           n=$((n + 1)); \
           if [ "$n" -ge 3 ]; then echo "npm install -g opencode-ai failed after 3 attempts" >&2; exit 1; fi; \
           echo "npm install -g opencode-ai failed (attempt $n/3), retrying in 5s..." >&2; \
           sleep 5; \
         done ) \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --home-dir /home/opencode-user --shell /bin/bash opencode-user
WORKDIR /workspace
RUN chown opencode-user:opencode-user /workspace

COPY entrypoint-opencode.sh /usr/local/bin/entrypoint.sh
COPY reconcile-repos.sh /usr/local/bin/reconcile-repos.sh
COPY inject-library.sh /usr/local/bin/inject-library.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/reconcile-repos.sh /usr/local/bin/inject-library.sh

USER opencode-user
ENV HOME=/home/opencode-user

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
