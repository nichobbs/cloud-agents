# codex:base — Codex CLI runner image.
#
# Provides the OpenAI Codex CLI inside an ephemeral container.
# The API server sets HARNESS=codex, MODEL, NATIVE_SESSION_ID, PROMPT,
# REPO_URL, BRANCH, and OPENAI_API_KEY at runtime.
#
# Build:  docker build -t codex:base -f docker/Dockerfile.codex docker
# Arch:   linux/amd64

FROM --platform=linux/amd64 node:20-slim

ENV DEBIAN_FRONTEND=noninteractive

# Pinned to a version confirmed to install cleanly (bump deliberately, not
# by dropping the pin back to @latest — an untested "latest" is what took
# the whole Coolify deploy down the first time this ran unpinned, see
# deploy/COOLIFY.md). The retry loop guards against transient npm-registry
# failures, the other documented cause of a mid-build failure here.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git bash curl ca-certificates jq \
    && ( n=0; until npm install -g @openai/codex@0.145.0; do \
           n=$((n + 1)); \
           if [ "$n" -ge 3 ]; then echo "npm install -g @openai/codex failed after 3 attempts" >&2; exit 1; fi; \
           echo "npm install -g @openai/codex failed (attempt $n/3), retrying in 5s..." >&2; \
           sleep 5; \
         done ) \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --home-dir /home/codex-user --shell /bin/bash codex-user
WORKDIR /workspace
RUN chown codex-user:codex-user /workspace

COPY entrypoint-codex.sh /usr/local/bin/entrypoint.sh
COPY reconcile-repos.sh /usr/local/bin/reconcile-repos.sh
COPY inject-library.sh /usr/local/bin/inject-library.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/reconcile-repos.sh /usr/local/bin/inject-library.sh

USER codex-user
ENV HOME=/home/codex-user

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
