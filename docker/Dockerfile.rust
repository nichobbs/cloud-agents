# claude-code:rust — Phase 4 tool pack.
#
# Extends the base runner with the Rust toolchain (cargo, rustc).
# Build:  docker build -t claude-code:rust -f docker/Dockerfile.rust docker
#
# Requires claude-code:base to be built first.

FROM claude-code:base

USER root
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:$PATH

RUN curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal \
    && chmod -R a+rwX /usr/local/cargo \
    && rustc --version

USER claude-user
