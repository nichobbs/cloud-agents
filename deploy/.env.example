# Copy to .env and fill in. docker-compose reads this file automatically.

# Server-side key used to encrypt stored user credentials (Phase 3).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Optional comma-separated whitelist of GitHub user IDs allowed to use the
# platform. Empty = open access to any authenticated GitHub user (Phase 3).
CLOUD_AGENTS_WHITELIST=

# Optional Docker network that runner containers join under the 'restricted'
# profile network policy. Create it internal (`docker network create --internal
# egress-net`) with an allowlisting proxy as its only route out. If empty,
# 'restricted' fails closed to NO network (its git clone will fail) rather than
# granting full egress — set this before relying on the 'restricted' policy.
CLOUD_AGENTS_RESTRICTED_NETWORK=

# Optional egress proxy URL. When set, 'restricted' containers also get
# HTTP(S)_PROXY env vars pointing here (advisory convenience for proxy-aware
# clients; the network above is the actual enforcement).
CLOUD_AGENTS_EGRESS_PROXY=
